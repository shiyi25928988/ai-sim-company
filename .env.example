# ─────────────────────────────────────────────
# ai-sim-company 环境变量样例。复制为 .env 后填入真实值。
# 后端启动时自动加载本文件 (aisim/__init__.py); docker compose 也自动读取。
# 已存在的环境变量优先 (shell/env 覆盖 .env)。
# ─────────────────────────────────────────────

# Redis - 本地开发 (宿主机 Redis 带密码)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0
# 或者直接给完整 URL (二选一; REDIS_URL 优先):
# REDIS_URL=redis://:123456@localhost:6379/0

# Agent 容器后端: simulated (本地开发默认) | docker (生产，需 Docker socket + agent 镜像)
AGENT_BACKEND=simulated

# LLM 网关 - API Key 只在这里配一次 (见架构设计 §七)
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini
# 是否启用 function-calling (CEO 招人等工具调用)。端点不支持工具时设 false，Agent 仍会思考(纯文本)
LLM_TOOLS_ENABLED=true
# 单个 Agent 单 tick 内 LLM<->工具 的最大循环轮数 (1=单轮最省; 3=可连续调多工具)。控成本
LLM_MAX_ITERS=3
# OpenAI 兼容端点 (可选): 留空用官方; 代理/国产兼容服务填此处
# 例: DeepSeek https://api.deepseek.com/v1 | 智谱 https://open.bigmodel.cn/api/paas/v4 | one-api http://localhost:3000/v1
LLM_BASE_URL=

# 仿真时钟 - 每个 Tick 的间隔 (毫秒)
TICK_INTERVAL_MS=5000
# 启动即跑时钟? false=暂停 (手动 play，省 LLM 成本); true=自动开始
SIM_AUTO_START=false
# Agent 每 N 个 tick 思考一次 (1=每次 tick 都调 LLM; 设大可省成本)
AGENT_THINK_EVERY=1
# 单步模式 (⏭) 下 Agent 之间的间隔 (ms)，控观察节奏
AGENT_STEP_DELAY_MS=800
