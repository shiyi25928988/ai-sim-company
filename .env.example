# ─────────────────────────────────────────────
# ai-sim-company environment variables example. Copy to .env and fill in real values.
# Auto-loaded by the backend on startup (aisim/__init__.py); docker compose also reads it.
# Existing env vars take precedence (shell/env overrides .env).
# These vars are referenced by config/company.yaml via ${VAR} placeholders.
# ─────────────────────────────────────────────

# Redis - local dev (host Redis with password)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0
# Or set the full URL (either/or; REDIS_URL takes precedence):
# REDIS_URL=redis://:123456@localhost:6379/0

# Agent container backend: simulated (local dev default) | docker (production; needs Docker socket + agent image)
AGENT_BACKEND=simulated

# LLM gateway - the API key is configured ONLY here (see design doc §7)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
# Enable function-calling (CEO hiring and other tool calls). Set false if the endpoint doesn't support tools;
# agents still think (plain text).
LLM_TOOLS_ENABLED=true
# Max LLM<->tool loop rounds per agent per tick (1 = single round, cheapest; 3 = can chain multiple tools). Cost control.
LLM_MAX_ITERS=3
# Daily LLM token budget (cost cap). -1 = unlimited (no cap); any value <= 0 disables it.
LLM_DAILY_BUDGET=2000000
# OpenAI-compatible endpoint (optional): empty = official OpenAI; proxy / compatible services go here.
# Examples: DeepSeek https://api.deepseek.com/v1 | Zhipu https://open.bigmodel.cn/api/paas/v4 | one-api http://localhost:3000/v1
LLM_BASE_URL=

# Simulation clock - interval per tick (ms)
TICK_INTERVAL_MS=5000
# Run the clock on startup? false = paused (manual Play, saves LLM cost); true = auto-start
SIM_AUTO_START=false
# Agent thinks once every N ticks (1 = every tick calls the LLM; larger saves cost)
AGENT_THINK_EVERY=1
# Interval between agents in step mode (ms), controls observation pace
AGENT_STEP_DELAY_MS=800
