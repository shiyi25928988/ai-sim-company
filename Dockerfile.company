# Dockerfile.company - Company Hub 镜像
#
# Company Hub 是系统中枢: 前端托管 + FastAPI/WebSocket + 仿真引擎 +
# LLM 统一网关 + Agent 容器编排 (Docker API) + Skill Pool + 消息路由。
# 它不做: Agent 的具体决策 / 代码执行 / Agent 个人记忆管理。

FROM python:3.12-slim

LABEL org.aisim.role="company-hub"

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY aisim/ ./aisim/
COPY config/ ./config/

# 8000 = FastAPI + WebSocket (前端实时通信)
EXPOSE 8000

# FastAPI 入口: aisim.api.server:app
CMD ["uvicorn", "aisim.api.server:app", "--host", "0.0.0.0", "--port", "8000"]
